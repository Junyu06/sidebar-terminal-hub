{
  "name": "sidebar-terminal-hub",
  "displayName": "Sidebar Terminal Hub",
  "description": "Embedded command-line terminal in the secondary sidebar",
  "publisher": "TerrysPlayground",
  "icon": "media/extension-icon.png",
  "version": "1.0.7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Junyu06/sidebar-terminal-hub.git"
  },
  "homepage": "https://github.com/Junyu06/sidebar-terminal-hub#readme",
  "bugs": {
    "url": "https://github.com/Junyu06/sidebar-terminal-hub/issues"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "sidebar",
    "cli",
    "secondary-sidebar",
    "xterm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "rst-terminal-secondary-container",
          "title": "Terminal",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "rst-terminal-secondary-container": [
        {
          "id": "rstTerminalSecondaryView",
          "name": "Terminal",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "terminalSidebar.open",
        "title": "Open Terminal Sidebar"
      },
      {
        "command": "terminalSidebar.newSession",
        "title": "New Terminal Session",
        "icon": "$(add)"
      },
      {
        "command": "terminalSidebar.closeActiveSession",
        "title": "Close Active Terminal Session",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "terminalSidebar.newSession",
          "when": "view == rstTerminalSecondaryView",
          "group": "navigation@1"
        },
        {
          "command": "terminalSidebar.closeActiveSession",
          "when": "view == rstTerminalSecondaryView && terminalSidebar.hasSessions",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:patch": "node ./scripts/package-patch.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openai/codex": "^0.111.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0"
  }
}
